{
  "name": "keysmith",
  "displayName": "keysmith",
  "description": "Generate secure secrets, API keys, and tokens directly inside VS Code.",
  "version": "1.0.1",
  "engines": {
    "vscode": "^1.116.0"
  },
  "publisher": "Ankush",
  "icon": "assets/images/key.png",
  "categories": [
    "Other"
  ],
  "repository": {
    "url": "https://github.com/CHELL-STAR/keysmith.git"
  },
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "keysmith.refresh",
        "title": "Refresh"
      },
      {
        "command": "keysmith.clear",
        "title": "Clear Output"
      },
      {
        "command": "keysmith.about",
        "title": "About"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "keysmith.refresh",
          "when": "view == keysmithView",
          "group": "secondary"
        },
        {
          "command": "keysmith.clear",
          "when": "view == keysmithView",
          "group": "secondary"
        },
        {
          "command": "keysmith.about",
          "when": "view == keysmithView",
          "group": "secondary"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "keysmith",
          "title": "Keysmith",
          "icon": "assets/images/key.svg"
        }
      ]
    },
    "views": {
      "keysmith": [
        {
          "type": "webview",
          "id": "keysmithView",
          "name": "Secret Generator",
          "icon": "assets/images/key.svg"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "build:webview": "cd webview && npm run build",
    "build:ext": "tsc -p ./",
    "build": "npm run build:webview && npm run build:ext"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "@types/vscode": "^1.116.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
